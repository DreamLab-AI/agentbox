# .env.example — copy to .env and fill in your values.
# Run: cp .env.example .env
# All values with a trailing comment of "required" must be set before up.
# Values with "optional" have safe defaults and can be left empty.
#
# After editing, run: ./agentbox.sh preflight
# to validate the environment before starting the container.

# -- Image reference -----------------------------------------------------------
# Leave empty to use the locally built image (default after agentbox.sh up --build).
# Set to a registry tag for agentbox.sh up --registry.
AGENTBOX_IMAGE_REF=

# -- AI provider keys ----------------------------------------------------------
# At least one key is required for agent operation.
ANTHROPIC_API_KEY=              # required for Claude Code / claude toolchain
GITHUB_TOKEN=                   # optional; needed for gh CLI and GitHub MCP tools
CRATES_TOKEN=                   # crates.io API token for `cargo publish` across ecosystem Rust crates
OPENAI_API_KEY=ollama           # set to real key if using OpenAI directly
OPENAI_BASE_URL=http://ollama:11434/v1  # change to http://host.docker.internal:11434/v1 if [networking].host_gateway=true + host ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:32b-instruct
GOOGLE_GEMINI_API_KEY=          # optional; for gemini-cli / Gemini provider
GEMINI_API_KEY=                 # alias accepted by some Gemini SDK versions

# -- Management API ------------------------------------------------------------
# Auto-generated at first boot and stored in the agentbox-secrets named volume.
# Leave empty on first run; the entrypoint writes to /var/lib/agentbox/secrets/mgmt-key.
# Set explicitly to use a fixed key across container recreations.
MANAGEMENT_API_KEY=
# hybrid: accepts Bearer tokens OR NIP-98 signed requests (default).
# strict-nip98 mode is planned but not yet implemented.
MANAGEMENT_API_AUTH_MODE=hybrid

# -- RuVector PostgreSQL -------------------------------------------------------
# Used when adapters.memory = "external-pg" or integrations.ruvector_external.enabled = true.
# Password must match what the ruvector-postgres container was initialised with.
# All three locations (entrypoint, docker-compose.override.yml, agentbox.toml conninfo)
# must use the same password. Source from this single var.
RUVECTOR_PG_PASSWORD=ruvector                        # change in production
RUVECTOR_USE_EXTERNAL=false                          # set true when using external-pg adapter

# -- Nostr / sovereign identity ------------------------------------------------
# Provide either AGENTBOX_NSEC (bech32 nsec1..., preferred) or AGENTBOX_PRIVKEY_HEX.
# If both are empty, the entrypoint generates a fresh keypair at boot and stores
# it in the agentbox-sovereign-identities named volume.
AGENTBOX_NSEC=                  # optional; bech32 nsec1...
AGENTBOX_PRIVKEY_HEX=           # optional; 64-char hex private key
# Operator pubkey: move here from agentbox.toml [sovereign_mesh.operator] for
# per-deployment identity. If set, the relay allowlist uses this pubkey instead
# of the manifest value. This prevents the checked-in manifest from binding the
# product repo to a specific operator.
AGENTBOX_NPUB=                  # optional; bech32 npub1...
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net

# -- Networking (Tailscale federation) -----------------------------------------
# Tailscale auth key for joining the tailnet. Create at:
#   https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for containers.
# Leave blank to disable Tailscale (default).
TAILSCALE_AUTHKEY=              # optional; tskey-auth-...

# Tailscale hostname for this container (MagicDNS name on the tailnet).
# Default: "agentbox" — override for multi-instance deployments.
TAILSCALE_HOSTNAME=agentbox

# -- ComfyUI -------------------------------------------------------------------
# Used by the ComfyUI MCP tool. Set to the ComfyUI API endpoint reachable from
# inside the container (Docker service DNS or host IP + host_gateway=true).
COMFYUI_API_ENDPOINT=http://comfyui:8188             # or http://host.docker.internal:8188
COMFYUI_LOCAL_ENDPOINT=http://comfyui:8188
COMFYUI_OUTPUTS=/run/comfyui/output

# -- Resource limits (referenced by docker-compose.override.yml) ---------------
# Tune to your host capacity. These are passed to docker deploy.resources.
# Hardcoding in override.yml couples the repo to a specific machine; use .env instead.
AGENTBOX_CPU_LIMIT=4
AGENTBOX_MEM_LIMIT=8G
AGENTBOX_CPU_RESERVE=1
AGENTBOX_MEM_RESERVE=2G

# -- Agent identity ------------------------------------------------------------
AGENTBOX_AGENT_ID=agentbox-core

# -- Observability (these are baked from agentbox.toml at Nix build time) ------
# Only set here to override the baked values without rebuilding the image.
# AGENTBOX_METRICS_PORT=9091
# AGENTBOX_OTLP_ENDPOINT=http://otel-collector:4317
# AGENTBOX_LOG_LEVEL=info
