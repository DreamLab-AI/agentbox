# Agentbox 2.0 environment

# Core providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=ollama
OPENAI_DEFAULT_MODEL=gpt-5.4
GOOGLE_GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GITHUB_TOKEN=
PERPLEXITY_API_KEY=
CONTEXT7_API_KEY=

# Local inference
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:32b-instruct

# Management API
MANAGEMENT_API_PORT=9090
MANAGEMENT_API_KEY=change-this-secret-key
MANAGEMENT_API_AUTH_MODE=hybrid

# Sovereign mesh
AGENTBOX_AGENT_ID=agentbox-core
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net
SOLID_POD_PORT=8484
SOLID_POD_ROOT=/var/lib/solid

# Runtime storage
RUVECTOR_DATA_DIR=/var/lib/ruvector
RUVECTOR_PORT=9700
WORKSPACE=/workspace
SHARED_PROJECTS_ROOT=/projects
CBM_CACHE_DIR=/workspace/.cache/codebase-memory-mcp

# Browser and QE
DISPLAY=:1
SCREENSHOT_DIR=/tmp/playwright-screenshots
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_HEADLESS=false
CHROMIUM_PATH=/usr/bin/chromium
QGIS_PORT=9877
BLENDER_PORT=9876
LINKEDIN_TIMEOUT=5000
DEFENSE_MCP_DRY_RUN=true
DEFENSE_MCP_REQUIRE_CONFIRMATION=true
DEFENSE_MCP_ALLOWED_DIRS=/tmp,/workspace,/var/log
DEFENSE_MCP_LOG_LEVEL=info
NAGUAL_API_KEY=
NAGUAL_BASE_URL=

# Docs and research
GOOGLE_API_KEY=
OPENROUTER_KEY=
REMOVEBG_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=
SUNO_API_KEY=
HEYGEN_API_KEY=
RUNWAY_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
DEEPGRAM_API_KEY=

# Skill service endpoints
COMFYUI_URL=http://localhost:8188
COMFYUI_WS_URL=ws://localhost:8188/ws
COMFYUI_OUTPUT_DIR=/tmp/comfyui-outputs
ZAI_URL=http://localhost:9600/chat
MANAGEMENT_API_URL=http://localhost:9090
