{
  "name": "agentic-flow-management-api",
  "version": "1.0.0",
  "description": "HTTP Management API for CachyOS Workstation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest"
  },
  "jest": {
    "roots": [
      "<rootDir>/tests/contract",
      "<rootDir>/tests/sovereign"
    ],
    "testMatch": [
      "**/*.contract.spec.js",
      "**/*.test.js"
    ],
    "testEnvironment": "node",
    "rootDir": "..",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/docker/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/",
      "/docker/"
    ]
  },
  "keywords": [
    "management",
    "api",
    "agentic-flow"
  ],
  "author": "Agentic Flow",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^10.0.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.44.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.47.0",
    "@opentelemetry/sdk-node": "^0.47.0",
    "fastify": "^4.26.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1"
  }
}
