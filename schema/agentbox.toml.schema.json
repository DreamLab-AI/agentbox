{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DreamLab-AI/agentbox/schema/agentbox.toml.schema.json",
  "title": "agentbox manifest",
  "description": "JSON Schema for agentbox.toml — the manifest-driven configuration for the agentbox container.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "core": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "orchestration": {
          "type": "string",
          "description": "Agent orchestrator implementation.",
          "examples": ["ruflo-v3"]
        },
        "vector_db": {
          "type": "string",
          "description": "Local retrieval engine.",
          "examples": ["ruvector-embedded"]
        }
      }
    },
    "federation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["standalone", "client"],
          "description": "Deployment shape: standalone (all local fallbacks) or client (federated with host mesh)."
        },
        "external_url": {
          "type": "string",
          "description": "Base URL of the host mesh. Required when mode=client."
        }
      }
    },
    "adapters": {
      "type": "object",
      "additionalProperties": false,
      "description": "Five-slot adapter configuration. Each slot resolves to one of three implementation classes.",
      "properties": {
        "beads": {
          "type": "string",
          "enum": ["local-sqlite", "external", "off"],
          "description": "Structured agent-work receipts adapter."
        },
        "pods": {
          "type": "string",
          "enum": ["local-solid-rs", "external", "off"],
          "description": "Durable linked-data storage adapter. local-solid-rs is the first-class first-party implementation (ADR-010); external federates with a host-provided Solid server; off returns AdapterDisabled. The legacy local-jss Python stub was removed in 2026-04-25 — operators with old manifests must flip to local-solid-rs and add the [security.exceptions.solid-pod-rs] writable-volume block."
        },
        "memory": {
          "type": "string",
          "enum": ["embedded-ruvector", "external-pg", "off"],
          "description": "Vector memory adapter."
        },
        "events": {
          "type": "string",
          "enum": ["local-jsonl", "external", "off"],
          "description": "Agent lifecycle event sink adapter."
        },
        "orchestrator": {
          "type": "string",
          "enum": ["local-process-manager", "stdio-bridge", "off"],
          "description": "Agent spawn and monitor channel adapter."
        }
      }
    },
    "gpu": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["none", "ollama-rocm", "ollama-cuda", "local-cuda"],
          "description": "GPU backend selection."
        }
      }
    },
    "desktop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable desktop environment."
        },
        "stack": {
          "type": "string",
          "enum": ["hyprland-wayland", "x11-openbox"],
          "description": "Desktop stack selection."
        },
        "resolution": {
          "type": "string",
          "description": "Display resolution, e.g. 1920x1080.",
          "pattern": "^[0-9]+x[0-9]+$"
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Port for the Prometheus /metrics endpoint. Default 9091."
        },
        "otlp_endpoint": {
          "type": "string",
          "description": "OpenTelemetry OTLP exporter endpoint. Empty = traces dropped."
        },
        "log_level": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error"],
          "description": "Structured log verbosity."
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "API-provider credential gates. Each key is a provider name.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "env_var"],
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether this provider is active. When true, env_var must be set in the environment (E017)."
          },
          "env_var": {
            "type": "string",
            "description": "Name of the environment variable holding the primary API key or token."
          },
          "optional_env_vars": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of optional supplementary env vars (e.g. base URL overrides).",
            "default": []
          },
          "auth_mode": {
            "type": "string",
            "enum": ["api_key", "oauth"],
            "default": "api_key",
            "description": "Credential model. \"api_key\" requires env_var to be set at boot (E017). \"oauth\" defers auth to an in-container CLI flow (e.g. `claude login`, `codex login`, `claude-zai login`) and skips the env-var check. Only currently honoured for anthropic, openai, and zai providers; other providers force api_key (W040)."
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "description": "Feature flags for manifest-gated skills.",
      "additionalProperties": false,
      "properties": {
        "browser": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "playwright": { "type": "boolean" },
            "qe_browser": { "type": "boolean" },
            "agent_browser": { "type": "boolean" }
          }
        },
        "media": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ffmpeg": { "type": "boolean" },
            "imagemagick": { "type": "boolean" },
            "comfyui_builtin": {
              "type": "boolean",
              "description": "Install ComfyUI as a built-in supervisor service on localhost:8188. Mutually exclusive with integrations.comfyui_external.enabled (E007)."
            }
          }
        },
        "spatial_and_3d": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "blender": { "type": "boolean" },
            "qgis": { "type": "boolean" },
            "gaussian_splatting": {
              "type": "boolean",
              "description": "Requires gpu.backend=local-cuda (E006)."
            }
          }
        },
        "data_science": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pytorch": { "type": "boolean" },
            "jupyter": { "type": "boolean" }
          }
        },
        "docs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "latex": { "type": "boolean" },
            "mermaid": { "type": "boolean" },
            "report_builder": { "type": "boolean" }
          }
        },
        "ontology": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Logseq OWL2 DL tools."
            }
          }
        }
      }
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude": { "type": "boolean" },
        "claude_code": { "type": "boolean" },
        "ruflo": { "type": "boolean" },
        "claude_flow": { "type": "boolean" },
        "agentic_qe": { "type": "boolean" },
        "nagual_qe": { "type": "boolean" },
        "codebase_memory": { "type": "boolean" },
        "rust": { "type": "boolean" },
        "gemini_cli": { "type": "boolean" },
        "codex": { "type": "boolean" },
        "code_server": { "type": "boolean" },
        "cuda": { "type": "boolean" }
      }
    },
    "integrations": {
      "type": "object",
      "description": "Integration-specific configuration sections.",
      "additionalProperties": false,
      "properties": {
        "ruvector_external": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "conninfo": {
              "type": "string",
              "description": "PostgreSQL DSN for external RuVector. Required when adapters.memory=external-pg (E002)."
            }
          }
        },
        "solid_pod_rs": {
          "type": "object",
          "additionalProperties": false,
          "description": "First-party Rust Solid Protocol 0.11 server (ADR-010). Consumed by the pods adapter when adapters.pods=local-solid-rs.",
          "properties": {
            "port":                  { "type": "integer", "minimum": 1, "maximum": 65535 },
            "bind":                  { "type": "string" },
            "storage":               { "type": "string", "enum": ["fs", "memory", "s3"] },
            "storage_root":          { "type": "string" },
            "base_url":              { "type": "string" },
            "enable_oidc":           { "type": "boolean" },
            "enable_schnorr_verify": { "type": "boolean" },
            "enable_dpop_cache":     { "type": "boolean", "description": "Requires enable_oidc=true (E033)." },
            "notifications":         { "type": "string", "enum": ["websocket", "webhook", "off"] },
            "log_level":             { "type": "string", "enum": ["trace", "debug", "info", "warn", "error"] },
            "enable_did_nostr":       { "type": "boolean", "description": "did:nostr resolver — maps did:nostr:<npub> to Solid WebIDs with alsoKnownAs cross-verification (Sprint 6 upstream)." },
            "enable_webhook_signing": { "type": "boolean", "description": "RFC 9421 Ed25519 signing of outbound Solid Notification webhooks (Sprint 6)." },
            "enable_rate_limit":      { "type": "boolean", "description": "Sliding-window LRU rate limiter (Sprint 7)." },
            "enable_quota":           { "type": "boolean", "description": "Per-pod storage quota via .quota.json sidecar (Sprint 8 P0)." },
            "jss_v04_compat":         { "type": "boolean", "description": "JavaScriptSolidServer v0.4 configuration/behaviour compatibility (Sprint 6-9)." },
            "rate_limit_per_sec":     { "type": "integer", "minimum": 1, "description": "Per-connection token-bucket ceiling when enable_rate_limit=true." },
            "quota_default_bytes":    { "type": "integer", "minimum": 0, "description": "Default per-pod storage ceiling when enable_quota=true." }
          }
        },
        "external_orchestrator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "protocol": {
              "type": "string",
              "enum": ["stdio", "http", "mcp"],
              "description": "Wire protocol for external orchestrator."
            }
          }
        },
        "external_events": {
          "type": "object",
          "additionalProperties": false,
          "description": "Required when adapters.events=external (E005).",
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string" },
            "relay_urls": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Nostr relay URL list."
            },
            "mcp_endpoint": { "type": "string" }
          }
        },
        "external_network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "network": { "type": "string" }
          }
        },
        "comfyui_external": {
          "type": "object",
          "additionalProperties": false,
          "description": "Point agentbox at a pre-existing ComfyUI instance. Mutually exclusive with skills.media.comfyui_builtin (E007).",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "When true, skip the built-in supervisor block and inject COMFYUI_URL / COMFYUI_WS_URL env vars."
            },
            "url": {
              "type": "string",
              "description": "HTTP base URL of the external ComfyUI instance."
            },
            "ws_url": {
              "type": "string",
              "description": "WebSocket URL of the external ComfyUI instance."
            }
          }
        }
      }
    },
    "consultants": {
      "type": "object",
      "additionalProperties": false,
      "description": "Consultant-tier MCP servers (PRD-005 / ADR-011). Each enabled consultant runs as a stdio-transport MCP server registered under skills/mcp.json so the Claude / ruflo coordinator can invoke it via the consult/health/cost_estimate tools.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Master gate. Setting any sub-consultant to enabled=true requires this to be true (E036)." },
        "log_dir": { "type": "string", "description": "JSONL audit-log root. Default /var/lib/agentbox/consultations." },
        "intelligence_signal": { "type": "boolean", "description": "When true, every successful consultation also writes an ADR-043 QualitySignal file to /workspace/profiles/<stack>/intelligence/data/." },
        "codex": {
          "type": "object",
          "additionalProperties": false,
          "description": "OpenAI Codex Rust CLI subprocess consultant. Requires providers.openai (E035) and toolchains.codex (E037).",
          "properties": {
            "enabled":    { "type": "boolean" },
            "model":      { "type": "string" },
            "home":       { "type": "string", "description": "CODEX_HOME path under the user-isolated openai-user account." },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
          }
        },
        "gemini": {
          "type": "object",
          "additionalProperties": false,
          "description": "@google/gemini-cli subprocess consultant. Requires providers.gemini (E035) and toolchains.gemini_cli (E037).",
          "properties": {
            "enabled":    { "type": "boolean" },
            "model":      { "type": "string" },
            "home":       { "type": "string", "description": "HOME under the gemini-user isolation." },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
          }
        },
        "zai": {
          "type": "object",
          "additionalProperties": false,
          "description": "Z.AI / GLM via Anthropic-compatible claude-zai subprocess. Requires providers.zai (E035).",
          "properties": {
            "enabled":    { "type": "boolean" },
            "model":      { "type": "string" },
            "home":       { "type": "string", "description": "HOME under the zai-user isolation." },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
          }
        },
        "perplexity": {
          "type": "object",
          "additionalProperties": false,
          "description": "Perplexity HTTPS API consultant. Requires providers.perplexity (E035).",
          "properties": {
            "enabled":    { "type": "boolean" },
            "model":      { "type": "string" },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
          }
        },
        "deepseek": {
          "type": "object",
          "additionalProperties": false,
          "description": "DeepSeek HTTPS API consultant. Requires providers.deepseek (E035).",
          "properties": {
            "enabled":    { "type": "boolean" },
            "model":      { "type": "string" },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
          }
        }
      }
    },
    "privacy_filter": {
      "type": "object",
      "additionalProperties": false,
      "description": "Local PII redaction sidecar (openai/privacy-filter). Routing contract: docs/reference/adr/ADR-008-privacy-filter-routing.md.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable the local openai/privacy-filter sidecar and adapter middleware."
        },
        "mode": {
          "type": "string",
          "enum": ["off", "local-gpu", "local-cpu"],
          "description": "off disables the sidecar; local-gpu requires a CUDA/ROCm backend (E023); local-cpu runs BF16 on CPU."
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Loopback port for the opf-router sidecar. Default 9092."
        },
        "dtype": {
          "type": "string",
          "enum": ["bf16", "f32", "q4"],
          "description": "Inference precision. q4 is CPU-only (E024)."
        },
        "model": {
          "type": "string",
          "description": "HF model id. Default openai/privacy-filter."
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-adapter-slot redaction policy. Values: strict | soft | off (E025).",
          "properties": {
            "pods":         { "type": "string", "enum": ["strict", "soft", "off"] },
            "memory":       { "type": "string", "enum": ["strict", "soft", "off"] },
            "events":       { "type": "string", "enum": ["strict", "soft", "off"] },
            "beads":        { "type": "string", "enum": ["strict", "soft", "off"] },
            "orchestrator": { "type": "string", "enum": ["strict", "soft", "off"] },
            "inbound":      { "type": "string", "enum": ["strict", "soft", "off"] },
            "outbound":     { "type": "string", "enum": ["strict", "soft", "off"] }
          }
        },
        "entities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "account_number", "private_address", "private_email",
                  "private_person", "private_phone", "private_url",
                  "private_date", "secret"
                ]
              },
              "description": "Entity classes to redact. Empty = all eight."
            }
          }
        }
      }
    },
    "sovereign_mesh": {
      "type": "object",
      "additionalProperties": false,
      "description": "Nostr identity, NIP-98 auth, inter-agent messaging, and optional daemons.",
      "properties": {
        "enabled": { "type": "boolean" },
        "solid_pod": { "type": "boolean" },
        "nostr_bridge": { "type": "boolean" },
        "https_bridge": { "type": "boolean" },
        "publish_agent_events": { "type": "boolean" },
        "telegram_mirror": {
          "type": "boolean",
          "description": "Requires CTM_BOT_TOKEN and CTM_TELEGRAM_CHAT_ID env vars (E014)."
        },
        "relay": {
          "type": "object",
          "additionalProperties": false,
          "description": "Embedded Nostr relay. See ADR-009 and PRD-004.",
          "properties": {
            "enabled":          { "type": "boolean" },
            "implementation":   { "type": "string",  "enum": ["nostr-rs-relay", "external", "off"], "description": "Relay backend. Only nostr-rs-relay is bundled today; rnostr was dropped from the enum because no flake supervisor branch wires it up." },
            "port":             { "type": "integer", "minimum": 1, "maximum": 65535 },
            "bind":             { "type": "string",  "description": "Loopback or 0.0.0.0. See E029." },
            "expose":           { "type": "boolean", "description": "Publish the port in docker-compose." },
            "data_dir":         { "type": "string" },
            "ingress_policy":   { "type": "string",  "enum": ["allowlist", "signed-only", "open"] },
            "allowed_pubkeys":  { "type": "array",   "items": { "type": "string" } },
            "allowed_kinds":    { "type": "array",   "items": { "type": "integer", "minimum": 0 } },
            "pod_bridge":       { "type": "boolean" },
            "external_fanout":  { "type": "string",  "enum": ["bidirectional", "publish-only", "subscribe-only", "off"] },
            "max_event_bytes":  { "type": "integer", "minimum": 1024 },
            "messages_per_sec": { "type": "integer", "minimum": 1 },
            "retention_days":   { "type": "integer", "minimum": 0 },
            "allow_nip04":      { "type": "boolean", "description": "Legacy unencrypted DMs. Warned by E031." },
            "info_description": { "type": "string" },
            "info_contact":     { "type": "string" }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "description": "Security hardening configuration. The baseline is always applied; exceptions add minimum necessary privilege for specific features.",
      "properties": {
        "exceptions": {
          "type": "object",
          "additionalProperties": false,
          "description": "Feature-keyed privilege exceptions. Each key must correspond to an enabled feature gate (E020).",
          "properties": {
            "desktop": {
              "type": "object",
              "additionalProperties": false,
              "description": "Extra tmpfs mounts for Hyprland/wayvnc. Enabled when desktop.enabled=true.",
              "properties": {
                "tmpfs": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Additional tmpfs mount paths beyond the hardened baseline."
                }
              }
            },
            "gpu-rocm": {
              "type": "object",
              "additionalProperties": false,
              "description": "ROCm device access. Enabled when gpu.backend=ollama-rocm.",
              "properties": {
                "devices": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Host device paths to expose (e.g. /dev/kfd, /dev/dri)."
                }
              }
            },
            "gpu-cuda": {
              "type": "object",
              "additionalProperties": false,
              "description": "NVIDIA runtime. Enabled when gpu.backend=ollama-cuda or local-cuda.",
              "properties": {
                "runtime": {
                  "type": "string",
                  "enum": ["nvidia"],
                  "description": "Docker runtime override."
                },
                "device_requests": {
                  "type": "array",
                  "description": "NVIDIA device_requests entries.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "driver": { "type": "string" },
                      "count": { "type": "integer" },
                      "capabilities": {
                        "type": "array",
                        "items": { "type": "array", "items": { "type": "string" } }
                      }
                    }
                  }
                }
              }
            },
            "gaussian-splatting": {
              "type": "object",
              "additionalProperties": false,
              "description": "3DGS compute. Inherits gpu-cuda.",
              "properties": {
                "inherits": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Exception names whose deltas are merged first."
                }
              }
            },
            "playwright": {
              "type": "object",
              "additionalProperties": false,
              "description": "Chromium sandbox capability. Enabled when skills.browser.playwright=true.",
              "properties": {
                "cap_add": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Linux capabilities to add (minimum: SYS_ADMIN for Chromium sandbox)."
                },
                "reason": {
                  "type": "string",
                  "description": "Human-readable justification for the privilege."
                }
              }
            },
            "code-server": {
              "type": "object",
              "additionalProperties": false,
              "description": "code-server config volume. Enabled when toolchains.code_server=true.",
              "properties": {
                "writable_volumes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Named volume mount strings appended to the service volumes list."
                }
              }
            },
            "telegram-mirror": {
              "type": "object",
              "additionalProperties": false,
              "description": "CTM config volume. Enabled when sovereign_mesh.telegram_mirror=true.",
              "properties": {
                "writable_volumes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Named volume mount strings appended to the service volumes list."
                }
              }
            },
            "nostr-relay": {
              "type": "object",
              "additionalProperties": false,
              "description": "Embedded Nostr relay data volume. Enabled when sovereign_mesh.relay.enabled=true.",
              "properties": {
                "writable_volumes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Named volume mount strings for the SQLite database and WAL."
                },
                "reason": { "type": "string" }
              }
            },
            "solid-pod-rs": {
              "type": "object",
              "additionalProperties": false,
              "description": "solid-pod-rs filesystem backend volume. Enabled when adapters.pods=local-solid-rs (ADR-010).",
              "properties": {
                "writable_volumes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Named volume mount strings for the .meta/.acl sidecars and atomic-rename temp files."
                },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "linked_data": {
      "type": "object",
      "additionalProperties": false,
      "description": "Linked-Data interchange surfaces (PRD-006 / ADR-012 / DDD-004). When [linked_data].enabled = false (default), no surface emits or consumes JSON-LD and zero behaviour changes vs. the pre-PRD-006 product. Each per-surface gate accepts on | emit | off. Validation rules: E040–E049.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master gate. When false every per-surface gate is forced off (E040)."
        },
        "pods": {
          "type": "string",
          "enum": ["on", "emit", "off"],
          "description": "S1 — Solid pod resource representations. Requires adapters.pods ∈ {local-solid-rs, external} (E041)."
        },
        "events": {
          "type": "string",
          "enum": ["on", "emit", "off"],
          "description": "S2 — Nostr envelope payloads. Requires [sovereign_mesh.relay].enabled = true (E042)."
        },
        "credentials": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S3 — W3C Verifiable Credentials. JCS canonicalisation required (E043)."
        },
        "did_documents": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S4 — DID Documents at /.well-known/did.json. Requires sovereign_mesh.solid_pod = true (E044)."
        },
        "provenance": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S5 — PROV-O receipts emitted parallel to the events adapter."
        },
        "capability_descriptors": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S6 — W3C WoT Thing Descriptions for MCP servers."
        },
        "skill_metadata": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S7 — Schema.org HowTo encoding for skills (build-time only)."
        },
        "payments": {
          "type": "string",
          "enum": ["on", "emit", "off"],
          "description": "S8 — agentic-payment mandates and receipts (VC + ODRL). JCS canonicalisation required (E043)."
        },
        "memory_catalogue": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S9 — DCAT-3 memory namespace catalogue at /v1/memory/catalogue."
        },
        "architecture_docs": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S10 — ADR/PRD/DDD frame frontmatter (build-time only)."
        },
        "http_meta": {
          "type": "string",
          "enum": ["emit", "off"],
          "description": "S11 — Content-negotiated JSON-LD on /v1/meta and /v1/agent-events."
        },
        "default_form": {
          "type": "string",
          "enum": ["compacted", "expanded", "flattened", "framed"],
          "description": "Default JSON-LD form when a surface does not pin one. Default compacted."
        },
        "context_catalogue": {
          "type": "string",
          "description": "Filesystem path of the pinned context catalogue. Default /opt/agentbox/contexts."
        },
        "context_cache_mode": {
          "type": "string",
          "enum": ["image", "bind", "off"],
          "description": "How the catalogue reaches the runtime. image (read-only image layer; default), bind (host bind-mount), off (rejected when any user-touching surface is on; E046)."
        },
        "unknown_context_policy": {
          "type": "string",
          "enum": ["fail-closed", "fail-open"],
          "description": "What to do when an UnpinnedContextIRI appears in input. Default fail-closed (E047 warns when fail-open is paired with pods=on)."
        },
        "canonicalisation": {
          "type": "string",
          "enum": ["jcs", "none"],
          "description": "Canonicalisation mode. jcs is required when credentials or payments surface is enabled (E043)."
        },
        "round_trip_in_dispatch": {
          "type": "boolean",
          "description": "Run the round-trip self-check on every dispatch. Default true. CI-only deployments may set false to save cycles."
        },
        "contexts": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Operator overrides for context IRIs. Each value MUST resolve to a pinned ContextDocument in lib/linked-data-contexts.nix (E045)."
        },
        "did": {
          "type": "object",
          "additionalProperties": false,
          "description": "DID method controls for S4.",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["nostr", "key", "web"],
              "description": "DID method. nostr is the default sovereign method; requires the did-nostr Cargo feature (E049)."
            },
            "service_endpoints": {
              "type": "array",
              "items": { "type": "string", "enum": ["pod", "relay"] },
              "description": "Which agentbox services to publish in the DID Document service array."
            },
            "publish_to_well_known": {
              "type": "boolean",
              "description": "Serve the DID Document at /.well-known/did.json via solid-pod-rs."
            }
          }
        },
        "privacy_handoff": {
          "type": "object",
          "additionalProperties": false,
          "description": "Privacy filter handoff (documentation only — the order is fixed in code).",
          "properties": {
            "order": {
              "type": "string",
              "enum": ["after"],
              "description": "Always after. The validator rejects any other value (E048)."
            }
          }
        }
      }
    }
  }
}
