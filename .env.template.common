# .env.template.common
# Infrastructure env vars shared across all provisioning targets.
# Copy to .env and fill in values, or let scripts/start-agentbox.sh guide you.

# ---- Agent identity --------------------------------------------------------
AGENTBOX_AGENT_ID=agentbox

# ---- API keys (optional — only set what you need) --------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ---- Management API --------------------------------------------------------
# Leave blank to auto-generate on first start (recommended).
MANAGEMENT_API_KEY=

# ---- Sovereign mesh --------------------------------------------------------
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# ---- Runtime ports (change if clashing with host services) -----------------
MANAGEMENT_API_PORT=9090
RUVECTOR_PORT=9700
SOLID_POD_PORT=8484

# ---- Feature flags (override agentbox.toml gates at runtime) ---------------
ENABLE_DESKTOP=false
ENABLE_PLAYWRIGHT=false
ENABLE_AGENT_BROWSER=false
ENABLE_CLAUDE_FLOW=false
ENABLE_RUFLO=false
ENABLE_AGENTIC_QE=false
ENABLE_NAGUAL_QE=false
ENABLE_CODEBASE_MEMORY=false
ENABLE_MERMAID=false
