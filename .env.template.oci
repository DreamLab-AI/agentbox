# .env.template.oci
# Oracle Cloud Infrastructure provisioner variables.
# Extends .env.template.common — set common vars there.

# ---- OCI tenancy -----------------------------------------------------------
OCI_TENANCY_OCID=ocid1.tenancy.oc1..
OCI_REGION=uk-london-1

# ---- Instance image --------------------------------------------------------
# Find current ARM images: oci compute image list --shape VM.Standard.A1.Flex
OCI_IMAGE_ID=ocid1.image.oc1.uk-london-1.

# ---- Instance sizing (free tier limits: 4 OCPU, 24 GB) --------------------
OCI_OCPUS=4
OCI_MEMORY_GB=24
OCI_INSTANCE_NAME=agentbox

# ---- SSH key ---------------------------------------------------------------
SSH_KEY_FILE=~/.ssh/agentbox_key.pub

# ---- OCI CLI path (defaults to ~/.local/bin/oci) ---------------------------
OCI_CMD=~/.local/bin/oci
