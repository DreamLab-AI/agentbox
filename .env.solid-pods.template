# Solid pod native server environment — agentbox deployment.
# Generated 2026-05-17. Keep this file secret — never commit.
# Matches: NATIVE_POD_ADMIN_KEY and NATIVE_POD_URL GH secrets on
# DreamLab-AI/dreamlab-ai-website (set 2026-05-17).

# Cloudflare Tunnel token — from Zero Trust → Tunnels → dreamlab-native-pods
# Set this before starting the sidecar stack.
CLOUDFLARE_TUNNEL_TOKEN=

# Pre-shared key for /_admin/provision/* endpoint.
# Must match NATIVE_POD_ADMIN_KEY CF Worker secret on dreamlab-auth-api.
SOLID_ADMIN_KEY=

# CORS allowed origins — must include the forum origin.
SOLID_ALLOWED_ORIGINS=[deployed website]]

# Public base URL (Cloudflare Tunnel hostname).
SOLID_POD_PUBLIC_URL=[cloudflare worker for website]
