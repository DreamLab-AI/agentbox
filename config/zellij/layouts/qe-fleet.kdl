layout {
    pane split_direction="vertical" {
        pane split_direction="horizontal" {
            pane command="fish" cwd="/workspace/profiles/qe-fleet" {
                args "-lc" "printf '\nAgentbox: qe-fleet\n\n'; exec bash"
            }
            pane command="fish" cwd="/workspace/profiles/qe-fleet" {
                args "-lc" "printf '\nBrowser / test runner view\n\n'; exec bash"
            }
        }
        pane split_direction="horizontal" {
            pane command="fish" cwd="/workspace/profiles/qe-fleet/projects" {
                args "-lc" "printf '\nMounted external projects\n\n'; exec bash"
            }
            pane command="fish" cwd="/workspace/profiles/qe-fleet/workspace" {
                args "-lc" "printf '\nArtifacts / screenshots\n\n'; exec bash"
            }
        }
    }
}
