layout {
    pane split_direction="vertical" {
        pane command="fish" cwd="/workspace/profiles/claude-core" {
            args "-lc" "printf '\nAgentbox: claude-core\n\n'; exec bash"
        }
        pane split_direction="horizontal" {
            pane command="fish" cwd="/workspace/profiles/claude-core" {
                args "-lc" "printf '\nSkills index\n\n'; exec bash"
            }
            pane command="fish" cwd="/workspace/profiles/claude-core" {
                args "-lc" "printf '\nShared projects\n\n'; exec bash"
            }
        }
    }
}
