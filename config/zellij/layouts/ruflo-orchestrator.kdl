layout {
    pane split_direction="vertical" {
        pane split_direction="horizontal" {
            pane command="fish" cwd="/workspace/profiles/ruflo-orchestrator" {
                args "-lc" "printf '\nAgentbox: ruflo-orchestrator\n\n'; exec bash"
            }
            pane command="fish" cwd="/workspace/profiles/ruflo-orchestrator" {
                args "-lc" "printf '\nRuVector / orchestration view\n\n'; exec bash"
            }
        }
        pane split_direction="horizontal" {
            pane command="fish" cwd="/workspace/profiles/ruflo-orchestrator/projects" {
                args "-lc" "printf '\nMounted external projects\n\n'; exec bash"
            }
            pane command="fish" cwd="/workspace/profiles/ruflo-orchestrator/workspace" {
                args "-lc" "printf '\nShared workspace\n\n'; exec bash"
            }
        }
    }
}
