layout {
  tab name="claude" focus=true {
    pane {
      command "fish"
      args "-C" "cd /workspace/project"
    }
  }

  tab name="ruflo" {
    pane {
      command "fish"
      args "-C" "cd /workspace && ruflo --version"
    }
  }

  tab name="qe" {
    pane {
      command "fish"
      args "-C" "cd /workspace && aqe --version"
    }
  }

  tab name="docs" {
    pane {
      command "fish"
      args "-C" "cd /opt/agentbox/docs && ls"
    }
  }

  tab name="build" {
    pane {
      command "fish"
      args "-C" "cd /workspace"
    }
  }

  tab name="logs" {
    pane {
      command "fish"
      args "-C" "svc"
    }
  }

  tab name="vcs" {
    pane {
      command "fish"
      args "-C" "cd /workspace/project && git status"
    }
  }

  tab name="memory" {
    pane {
      command "fish"
      args "-C" "claude-flow --version"
    }
  }

  tab name="llm" {
    pane {
      command "fish"
    }
  }

  tab name="agents" {
    pane {
      command "fish"
      args "-C" "ls /opt/agentbox/skills"
    }
  }

  tab name="host-shell" {
    pane {
      command "fish"
      args "-C" "echo 'Out-of-band host shell'"
    }
  }
}
