{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.0.0",
  "description": "MCP Server Registry for Agentbox",
  "mcpServers": {
    "claude-flow": {
      "command": "claude-flow",
      "args": ["mcp", "start"],
      "type": "stdio",
      "env": {
        "HOME": "/home/devuser",
        "CLAUDE_FLOW_PLUGIN_DIR": "/home/devuser/.claude-flow/plugins",
        "TRANSFORMERS_CACHE": "/home/devuser/.cache/huggingface",
        "HF_HOME": "/home/devuser/.cache/huggingface"
      }
    },
    "ruv-swarm": {
      "command": "npx",
      "args": ["ruv-swarm@latest", "mcp", "start"],
      "type": "stdio"
    },
    "imagemagick": {
      "command": "python3",
      "args": ["-u", "/home/devuser/.claude/skills/imagemagick/mcp-server/server.py"],
      "type": "stdio",
      "env": {
        "IMAGEMAGICK_TIMEOUT": "300"
      },
      "description": "Image processing with format conversion, resizing, cropping, batch operations",
      "protocol": "fastmcp",
      "version": "2.0.0"
    },
    "qgis": {
      "command": "python3",
      "args": ["-u", "/home/devuser/.claude/skills/qgis/mcp-server/server.py"],
      "type": "stdio",
      "env": {
        "QGIS_HOST": "localhost",
        "QGIS_PORT": "9877",
        "QGIS_TIMEOUT": "60"
      },
      "description": "Geospatial analysis and GIS operations via QGIS",
      "protocol": "fastmcp",
      "version": "2.0.0"
    },
    "playwright": {
      "command": "node",
      "args": ["/home/devuser/.claude/skills/playwright/mcp-server/server.js"],
      "type": "stdio",
      "env": {
        "DISPLAY": ":1",
        "CHROMIUM_PATH": "/usr/bin/chromium",
        "PLAYWRIGHT_TIMEOUT": "30000",
        "PLAYWRIGHT_OUTPUT_DIR": "/tmp/playwright-mcp",
        "CHROMIUM_WEBGPU": "true",
        "VIEWPORT_WIDTH": "1920",
        "VIEWPORT_HEIGHT": "1080"
      },
      "description": "Browser automation — @playwright/mcp with accessibility-tree snapshots, network interception, WebGPU via ANGLE-Vulkan on DISPLAY=:1 (Xvnc). VNC on port 5901.",
      "protocol": "mcp-sdk",
      "version": "3.0.0"
    },
    "web-summary": {
      "command": "python3",
      "args": ["-u", "/home/devuser/.claude/skills/web-summary/mcp-server/server.py"],
      "type": "stdio",
      "env": {
        "ZAI_URL": "http://localhost:9600/chat",
        "ZAI_TIMEOUT": "60"
      },
      "description": "URL summarization with YouTube transcripts and topic generation",
      "protocol": "fastmcp",
      "version": "2.0.0"
    },
    "comfyui": {
      "command": "node",
      "args": ["/home/devuser/.claude/skills/comfyui/mcp-server/server.js"],
      "type": "stdio",
      "env": {
        "COMFYUI_OUTPUT_DIR": "/tmp/comfyui-outputs",
        "ZAI_URL": "http://localhost:9600/chat",
        "DISPLAY": ":1"
      },
      "description": "AI image and video generation with ComfyUI. COMFYUI_URL and COMFYUI_WS_URL are resolved from the image environment (set by flake.nix from agentbox.toml integrations.comfyui_external or builtin path).",
      "protocol": "mcp-sdk",
      "version": "1.0.0"
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"],
      "type": "stdio",
      "env": {
        "BLENDER_HOST": "localhost",
        "BLENDER_PORT": "9876"
      },
      "description": "3D modeling, scene creation, rendering, PolyHaven assets, Sketchfab, Hyper3D Rodin via Blender MCP (ahujasid/blender-mcp)",
      "protocol": "mcp-fastmcp",
      "version": "1.4.0",
      "features": ["viewport_screenshots", "polyhaven", "sketchfab", "hyper3d_rodin", "hunyuan3d", "code_execution"]
    }
  },
  "external_bridge": {
    "tcp_bridge": {
      "host": "external-mcp-bridge",
      "port": 9500,
      "protocol": "json-rpc"
    },
    "discovery": {
      "enabled": true,
      "resource_pattern": "{skill}://capabilities"
    },
    "tools": [
      "session_status",
      "session_agents",
      "session_metrics",
      "swarm_list",
      "swarm_monitor",
      "agent_metrics",
      "performance_summary"
    ]
  },
  "services": {
    "zai": {
      "url": "http://localhost:9600",
      "internal_only": true,
      "worker_pool": 4,
      "max_queue": 50
    },
    "management_api": {
      "url": "http://localhost:9090",
      "auth_header": "X-API-Key"
    },
    "ragflow": {
      "url": "http://docker-ragflow-cpu-1:80",
      "api_url": "http://docker-ragflow-cpu-1:9380",
      "network": "docker_ragflow",
      "description": "RAGFlow knowledge management and semantic search"
    },
    "whisper": {
      "url": "http://whisper-webui:7860",
      "network": "docker_ragflow",
      "description": "Whisper STT speech-to-text transcription"
    },
    "comfyui": {
      "url": "http://comfyui:8188",
      "ws_url": "ws://comfyui:8188/ws",
      "network": "docker_ragflow",
      "description": "ComfyUI AI image generation (external deployment reference; override via integrations.comfyui_external in agentbox.toml)"
    },
    "neo4j": {
      "bolt_url": "bolt://external-neo4j:7687",
      "http_url": "http://external-neo4j:7474",
      "network": "docker_ragflow",
      "description": "Neo4j graph database"
    },
    "jss": {
      "url": "http://external-jss:3030",
      "ws_url": "ws://external-jss:3030/.notifications",
      "network": "docker_ragflow",
      "description": "JavaScript Solid Server for Solid Protocol pods"
    },
    "qdrant": {
      "url": "http://qdrant:6333",
      "grpc_url": "grpc://qdrant:6334",
      "network": "docker_ragflow",
      "description": "Qdrant vector database"
    },
    "xinference": {
      "url": "http://xinference:9997",
      "network": "docker_ragflow",
      "description": "Xinference model inference server"
    }
  }
}
